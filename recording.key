# AES-256 recording key, shared by the firmware build (CMake generates
# recording_key.h from this file) and decode_emgx.py (reads it directly).
#
# !!! PLACEHOLDER TEST KEY — replace before any real deployment. !!!
# !!! Anyone with this repository can decrypt recordings made with it. !!!
#
# key: 64 hex characters; id/version are stored in every file header so
# recordings remain attributable to a key after rotation.

key     = 000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
id      = 1
version = 1
